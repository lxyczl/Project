{
  "patterns": [
    {"id": "cliche_001", "type": "cliche", "match": "in recent years", "replacements": ["recently", "over the past decade", "lately"]},
    {"id": "cliche_002", "type": "cliche", "match": "it is worth noting that", "replacements": ["notably", "importantly", "a key point is"]},
    {"id": "cliche_003", "type": "cliche", "match": "plays a(?:n)? (?:important|crucial|significant) role", "replacements": ["is central to", "is fundamental to", "underpins"]},
    {"id": "cliche_004", "type": "cliche", "match": "has gained (?:significant|considerable|increasing) attention", "replacements": ["has been widely studied", "has become a focus", "has drawn interest"]},
    {"id": "cliche_005", "type": "cliche", "match": "a growing body of evidence", "replacements": ["accumulated research", "recent findings", "multiple studies"]},
    {"id": "cliche_006", "type": "cliche", "match": "the results (?:indicate|suggest|demonstrate|reveal) that", "replacements": ["findings show", "data point to", "analysis reveals"]},
    {"id": "cliche_007", "type": "cliche", "match": "this study aims to", "replacements": ["this paper investigates", "we examine", "the objective here is"]},
    {"id": "cliche_008", "type": "cliche", "match": "it is well known that", "replacements": ["established research shows", "it is widely accepted that", "the literature confirms"]},
    {"id": "cliche_009", "type": "cliche", "match": "in light of the above", "replacements": ["given these findings", "considering this", "with this in mind"]},
    {"id": "cliche_010", "type": "cliche", "match": "in the context of", "replacements": ["within", "in", "regarding"]},
    {"id": "cliche_011", "type": "cliche", "match": "with regard to", "replacements": ["regarding", "concerning", "for"]},
    {"id": "cliche_012", "type": "cliche", "match": "in terms of", "replacements": ["for", "regarding", "when considering"]},
    {"id": "cliche_013", "type": "cliche", "match": "over the past few decades", "replacements": ["in recent decades", "since the late 20th century", "in the last 30 years"]},
    {"id": "cliche_014", "type": "cliche", "match": "has attracted considerable interest", "replacements": ["has been extensively studied", "has drawn research attention", "has become a research focus"]},
    {"id": "cliche_015", "type": "cliche", "match": "as a matter of fact", "replacements": ["in fact", "indeed", "actually"]},

    {"id": "conn_001", "type": "connector", "match": "\\bfurthermore\\b", "replacements": ["moreover", "in addition", "also"]},
    {"id": "conn_002", "type": "connector", "match": "\\bmoreover\\b", "replacements": ["furthermore", "additionally", "also"]},
    {"id": "conn_003", "type": "connector", "match": "\\bconsequently\\b", "replacements": ["as a result", "thus", "therefore"]},
    {"id": "conn_004", "type": "connector", "match": "\\bnevertheless\\b", "replacements": ["however", "yet", "still"]},
    {"id": "conn_005", "type": "connector", "match": "\\badditionally\\b", "replacements": ["also", "furthermore", "in addition"]},
    {"id": "conn_006", "type": "connector", "match": "\\bsubsequently\\b", "replacements": ["later", "afterward", "then"]},
    {"id": "conn_007", "type": "connector", "match": "\\baccordingly\\b", "replacements": ["thus", "therefore", "as a result"]},
    {"id": "conn_008", "type": "connector", "match": "\\bhence\\b", "replacements": ["therefore", "thus", "so"]},
    {"id": "conn_009", "type": "connector", "match": "\\bnonetheless\\b", "replacements": ["however", "despite this", "still"]},
    {"id": "conn_010", "type": "connector", "match": "\\blikewise\\b", "replacements": ["similarly", "in the same way", "also"]},

    {"id": "formal_001", "type": "formal", "match": "in order to", "replacements": ["to", "so as to"]},
    {"id": "formal_002", "type": "formal", "match": "due to the fact that", "replacements": ["because", "since", "as"]},
    {"id": "formal_003", "type": "formal", "match": "in the event that", "replacements": ["if", "should", "when"]},
    {"id": "formal_004", "type": "formal", "match": "for the purpose of", "replacements": ["to", "for", "in order to"]},
    {"id": "formal_005", "type": "formal", "match": "in the process of", "replacements": ["while", "during", "when"]},
    {"id": "formal_006", "type": "formal", "match": "at this point in time", "replacements": ["now", "currently", "presently"]},
    {"id": "formal_007", "type": "formal", "match": "in spite of the fact", "replacements": ["although", "despite", "even though"]},
    {"id": "formal_008", "type": "formal", "match": "on the basis of", "replacements": ["based on", "from", "according to"]},
    {"id": "formal_009", "type": "formal", "match": "with the exception of", "replacements": ["except", "apart from", "excluding"]},
    {"id": "formal_010", "type": "formal", "match": "in accordance with", "replacements": ["following", "per", "according to"]},

    {"id": "syntax_001", "type": "sentence_pattern", "match": "not only .* but also", "replacements": ["both ... and", "... as well as ...", "in addition to ... , also ..."]},
    {"id": "syntax_002", "type": "sentence_pattern", "match": "it has been (?:shown|demonstrated|found|observed|reported|suggested) that", "replacements": ["research shows", "studies confirm", "findings indicate"]},
    {"id": "syntax_003", "type": "sentence_pattern", "match": "there (?:is|are) a (?:growing|increasing|significant) (?:need|demand|interest|concern)", "replacements": ["researchers increasingly focus on", "the field is moving toward", "attention is shifting to"]},
    {"id": "syntax_004", "type": "sentence_pattern", "match": "the (?:present|current) study", "replacements": ["this study", "this research", "this investigation"]},
    {"id": "syntax_005", "type": "sentence_pattern", "match": "as (?:mentioned|discussed|noted|described) (?:above|earlier|previously)", "replacements": ["as shown", "as outlined", "as described"]},

    {"id": "passive_001", "type": "passive", "match": "it can be (?:seen|observed|noted|concluded|argued) that", "replacements": ["we can see that", "this shows that", "evidence suggests"]},
    {"id": "passive_002", "type": "passive", "match": "has been (?:widely|extensively|commonly) (?:used|applied|adopted|employed)", "replacements": ["is common in", "is standard practice in", "remains popular in"]}
  ],
  "protected_terms": [
    "DRASTIC", "InVEST", "OWA", "SHAP", "GIS", "LSTM", "CNN", "RNN",
    "GRU", "GAN", "BERT", "GPT", "ResNet", "VGG", "YOLO",
    "evapotranspiration", "infiltration", "runoff", "watershed",
    "groundwater", "aquifer", "hydraulic", "hydrological",
    "ecosystem", "biodiversity", "biomass", "photosynthesis"
  ]
}
